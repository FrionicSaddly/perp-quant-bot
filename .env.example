# Copy this file to .env and fill in your keys. NEVER commit .env.
#
# Bybit TESTNET keys (create at https://testnet.bybit.com -> API Management).
# These are play-money keys. Do NOT put mainnet keys here while developing.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Optional: OpenNews / 6551 token for the news+sentiment feature (https://6551.io/mcp)
OPENNEWS_TOKEN=

# Optional: FRED key for macro features (https://fred.stlouisfed.org)
FRED_API_KEY=
